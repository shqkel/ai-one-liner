{
  "manifest_version": 3,
  "name": "AI One-Liner",
  "version": "1.0.0",
  "description": "텍스트를 선택하면 AI가 한 줄로 설명해줍니다",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [{
    "resources": ["icons/icon48.png"],
    "matches": ["<all_urls>"]
  }]
}
